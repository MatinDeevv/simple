  "hypothesis": {
    "statement": "The frozen stat-arb v0.2.1 conditional three-class basket probabilities are better calibrated than the train-only conditional comparator on untouched data.",
    "economic_mechanism": "Temporary cross-pair dislocations revert within the holding horizon while the basket's hedged structure suppresses common-mode drift.",
    "expected_direction": "positive Brier and log-loss improvement over the train-only conditional comparator",
    "expected_holding_horizon": "30 one-minute steps",
    "expected_failure_mode": "regime break in cross-pair coupling erases the conditional structure",
    "why_effect_exists": "liquidity provision is slow to reprice correlated pairs after idiosyncratic shocks",
    "why_effect_might_disappear": "faster arbitrageurs, structural correlation change, or overfit conditional cells"
  },
