# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
.venv-quantum/
venv/
env/
.env

# Generated data.  Git keeps directory sentinels only; full datasets belong
# in local storage during development and object storage in deployed research.
/data/raw/*
!/data/raw/.gitkeep
/data/canonical/*
!/data/canonical/.gitkeep
/data/derived/*
!/data/derived/.gitkeep
*.zip

# Logs
*.log
download_log.txt

# CI/local verification artifacts
/artifacts/*
!/artifacts/.gitkeep
!/artifacts/runs/
/artifacts/runs/*
!/artifacts/runs/.gitkeep
!/artifacts/figures/
/artifacts/figures/*
!/artifacts/figures/.gitkeep

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.agents/receipts/
